{
  "name": "@getengram/mcp-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply engram-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply engram-db --remote",
    "seed": "node --loader tsx scripts/seed.ts"
  },
  "dependencies": {
    "@getengram/db": "workspace:*",
    "@getengram/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "hono": "^4.12.12",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@getengram/sdk": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.77.0"
  }
}
